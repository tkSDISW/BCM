          </ownedFunctionalChains>
          <ownedFunctionalChains xsi:type="org.polarsys.capella.core.data.oa:OperationalProcess"
              id="40c6017c-8d4f-41f8-a0d5-703825584800" name="Bleed celll" description="&lt;ol>&#xA;&#x9;&lt;li style=&quot;margin-top: 16px; margin-bottom: 16px;&quot;>&lt;span style=&quot;font-style: normal;&quot;>&lt;span style=&quot;font-weight: normal;&quot;>&lt;span style=&quot;tab-stops: list .5in;&quot;>&lt;b>Passive Balancing&lt;/b>:&lt;/span>&lt;/span>&lt;/span>&#xA;&#x9;&lt;ul style=&quot;list-style-type: disc;&quot;>&#xA;&#x9;&#x9;&lt;li style=&quot;margin-top: 16px; margin-bottom: 16px;&quot;>&lt;span style=&quot;font-style: normal;&quot;>&lt;span style=&quot;font-weight: normal;&quot;>&lt;span style=&quot;tab-stops: list 1.0in;&quot;>&lt;b>Resistive Bleeding&lt;/b>: Passive balancing typically involves discharging the energy from higher-charged cells through a resistive path to dissipate the excess energy as heat.&lt;/span>&lt;/span>&lt;/span>&lt;/li>&#xA;&#x9;&#x9;&lt;li style=&quot;margin-top: 16px; margin-bottom: 16px;&quot;>&lt;span style=&quot;font-style: normal;&quot;>&lt;span style=&quot;font-weight: normal;&quot;>&lt;span style=&quot;tab-stops: list 1.0in;&quot;>&lt;b>Equalization&lt;/b>: The goal is to equalize the SOC of all cells by letting the more charged cells lose energy until they match the level of the least charged cell.&lt;/span>&lt;/span>&lt;/span>&lt;/li>&#xA;&#x9;&lt;/ul>&#xA;&#x9;&lt;/li>&#xA;&lt;/ol>&#xA;">
            <ownedFunctionalChainInvolvements xsi:type="org.polarsys.capella.core.data.fa:FunctionalChainInvolvementLink"
                id="546df260-3fc9-432d-97f4-b28aa3a12a21" involved="#189cd976-deb8-48ae-932b-9ee63ec74911"
                source="#bea3e2b6-5d97-478b-85b2-1e6a13c36a9d" target="#5a6a0a2f-a431-43d9-8fab-f1b4354317a5"/>
            <ownedFunctionalChainInvolvements xsi:type="org.polarsys.capella.core.data.fa:FunctionalChainInvolvementFunction"
                id="5a6a0a2f-a431-43d9-8fab-f1b4354317a5" involved="#f72243ae-1076-413e-88c5-d84cae028d29"/>

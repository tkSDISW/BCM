        <ownedSystemComponents xsi:type="org.polarsys.capella.core.data.ctx:SystemComponent"
            id="bd51a390-ca80-465c-9881-83c56a03da60" name="Battery Junction Box"
            description="&lt;ol>&#xA;&#x9;&lt;li style=&quot;list-style-type: none;&quot;>&#xA;&#x9;&lt;ol style=&quot;list-style-type: lower-alpha;&quot;>&#xA;&#x9;&#x9;&lt;li>&lt;span style=&quot;font-style: normal;&quot;>&lt;span style=&quot;font-weight: normal;&quot;>&lt;b>Role:&lt;/b> Manages the high-voltage connections and protections within the battery system. &lt;a href=&quot;https://www.einfochips.com/blog/technical-deep-dive-into-battery-management-system-architecture/?utm_source=chatgpt.com&quot;>&lt;font color=&quot;#467886&quot;>eInfochips&lt;/font>&lt;/a>&lt;/span>&lt;/span>&lt;/li>&#xA;&#x9;&#x9;&lt;li>&lt;span style=&quot;font-size: 12pt;&quot;>&lt;span style=&quot;font-family: &amp;quot;Aptos&amp;quot;,sans-serif;&quot;>&lt;span style=&quot;font-style: normal;&quot;>&lt;span style=&quot;font-weight: bold;&quot;>&lt;b>Functions:&lt;/b>&lt;/span>&lt;/span>&lt;/span>&lt;/span>&#xA;&#x9;&#x9;&lt;ol style=&quot;list-style-type: lower-roman;&quot;>&#xA;&#x9;&#x9;&#x9;&lt;li>&lt;span style=&quot;font-size: 12pt;&quot;>&lt;span style=&quot;color: rgb(0, 0, 0);&quot;>&lt;span style=&quot;font-family: &amp;quot;Aptos&amp;quot;,sans-serif;&quot;>&lt;span style=&quot;font-style: normal;&quot;>&lt;span style=&quot;font-weight: normal;&quot;>Handles current sensing and high-voltage interconnections.&lt;/span>&lt;/span>&lt;/span>&lt;/span>&lt;/span>&lt;/li>&#xA;&#x9;&#x9;&#x9;&lt;li>&lt;span style=&quot;font-size: 12pt;&quot;>&lt;span style=&quot;color: rgb(0, 0, 0);&quot;>&lt;span style=&quot;font-family: &amp;quot;Aptos&amp;quot;,sans-serif;&quot;>&lt;span style=&quot;font-style: normal;&quot;>&lt;span style=&quot;font-weight: normal;&quot;>Performs isolation monitoring to detect electrical faults.&lt;/span>&lt;/span>&lt;/span>&lt;/span>&lt;/span>&lt;/li>&#xA;&#x9;&#x9;&#x9;&lt;li>&lt;span style=&quot;font-size: 12pt;&quot;>&lt;span style=&quot;color: rgb(0, 0, 0);&quot;>&lt;span style=&quot;font-family: &amp;quot;Aptos&amp;quot;,sans-serif;&quot;>&lt;span style=&quot;font-style: normal;&quot;>&lt;span style=&quot;font-weight: normal;&quot;>Communicates with the BMU to relay critical information.&lt;/span>&lt;/span>&lt;/span>&lt;/span>&lt;/span>&lt;/li>&#xA;&#x9;&#x9;&lt;/ol>&#xA;&#x9;&#x9;&lt;/li>&#xA;&#x9;&lt;/ol>&#xA;&#x9;&lt;/li>&#xA;&lt;/ol>&#xA;&#xA;&lt;p>&lt;font color=&quot;#000000&quot;>&lt;b>&lt;span style=&quot;font-size: 12pt;&quot;>&lt;span style=&quot;line-height: 116%;&quot;>&lt;span style=&quot;font-family: &amp;quot;Aptos&amp;quot;,sans-serif;&quot;>Communication:&lt;/span>&lt;/span>&lt;/span>&lt;/b>&lt;span style=&quot;font-size: 12pt;&quot;>&lt;span style=&quot;line-height: 116%;&quot;>&lt;span style=&quot;font-family: &amp;quot;Aptos&amp;quot;,sans-serif;&quot;> The BJB interfaces with the BMU, often using CAN or other automotive communication protocols. &lt;/span>&lt;/span>&lt;/span>&lt;/font>&lt;/p>&#xA;"
            actor="true">

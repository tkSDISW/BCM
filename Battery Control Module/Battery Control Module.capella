              id="f52d8e15-7d32-4723-9c6e-83a35a6fedc4" name="Manage Cells" description="&lt;p>&lt;span style=&quot;color: black; line-height: 116%; font-family: &amp;quot;system-ui&amp;quot;,serif; font-size: 10.5pt; mso-fareast-font-family: system-ui; mso-bidi-font-family: system-ui; mso-themecolor: text1; mso-ansi-language: EN-US; mso-fareast-language: JA; mso-bidi-language: AR-SA;&quot;>Monitor cell:&lt;/span>&lt;/p>&#xA;&#xA;&lt;p>&lt;span style=&quot;color: black; line-height: 116%; font-family: &amp;quot;system-ui&amp;quot;,serif; font-size: 10.5pt; mso-fareast-font-family: system-ui; mso-bidi-font-family: system-ui; mso-themecolor: text1; mso-ansi-language: EN-US; mso-fareast-language: JA; mso-bidi-language: AR-SA;&quot;>&lt;span style=&quot;color: black; line-height: 116%; font-family: &amp;quot;system-ui&amp;quot;,serif; font-size: 10.5pt; mso-fareast-font-family: system-ui; mso-bidi-font-family: system-ui; mso-themecolor: text1; mso-ansi-language: EN-US; mso-fareast-language: JA; mso-bidi-language: AR-SA;&quot;>voltage&lt;/span>&lt;/span>&lt;/p>&#xA;&#xA;&lt;p>&lt;span style=&quot;color: black; line-height: 116%; font-family: &amp;quot;system-ui&amp;quot;,serif; font-size: 10.5pt; mso-fareast-font-family: system-ui; mso-bidi-font-family: system-ui; mso-themecolor: text1; mso-ansi-language: EN-US; mso-fareast-language: JA; mso-bidi-language: AR-SA;&quot;>temperature&lt;/span>&lt;/p>&#xA;&#xA;&lt;p>&lt;span style=&quot;color: black; line-height: 116%; font-family: &amp;quot;system-ui&amp;quot;,serif; font-size: 10.5pt; mso-fareast-font-family: system-ui; mso-bidi-font-family: system-ui; mso-themecolor: text1; mso-ansi-language: EN-US; mso-fareast-language: JA; mso-bidi-language: AR-SA;&quot;>state of charge&lt;/span>&lt;/p>&#xA;&#xA;&lt;p>&lt;span style=&quot;color: black; line-height: 116%; font-family: &amp;quot;system-ui&amp;quot;,serif; font-size: 10.5pt; mso-fareast-font-family: system-ui; mso-bidi-font-family: system-ui; mso-themecolor: text1; mso-ansi-language: EN-US; mso-fareast-language: JA; mso-bidi-language: AR-SA;&quot;>active cell balancing via resistive bleeding of voltage balanceing&lt;/span>&lt;/p>&#xA;"/>

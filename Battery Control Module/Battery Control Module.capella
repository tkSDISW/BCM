                id="dc587c8a-b325-43cf-b5fb-de75bd5aeb3a" involved="#4f3f252b-3ee5-4c6d-b4e3-35915dc906e6"/>
          </ownedFunctionalChains>
          <ownedFunctionalChains xsi:type="org.polarsys.capella.core.data.oa:OperationalProcess"
              id="af998f18-1a3d-41e2-842d-f6f84d88e0d5" name="balance cells" description="&lt;ul>&#xA;&#x9;&lt;li style=&quot;list-style-type: none;&quot;>&#xA;&#x9;&lt;ul style=&quot;list-style-type: disc;&quot;>&#xA;&#x9;&#x9;&lt;li style=&quot;margin-top: 16px; margin-bottom: 16px;&quot;>&lt;span style=&quot;font-style: normal;&quot;>&lt;span style=&quot;font-weight: normal;&quot;>&lt;span style=&quot;tab-stops: list 1.0in;&quot;>&lt;b>Energy Redistribution&lt;/b>: Active balancing involves redistributing energy from cells with higher SOC to those with lower SOC using inductors, capacitors, or DC-DC converters.&lt;/span>&lt;/span>&lt;/span>&lt;/li>&#xA;&#x9;&#x9;&lt;li style=&quot;margin-top: 16px; margin-bottom: 16px;&quot;>&lt;span style=&quot;font-style: normal;&quot;>&lt;span style=&quot;font-weight: normal;&quot;>&lt;span style=&quot;tab-stops: list 1.0in;&quot;>&lt;b>Charge Transfer&lt;/b>: This method transfers energy between cells, ensuring that no energy is lost in the process.&lt;/span>&lt;/span>&lt;/span>&lt;/li>&#xA;&#x9;&lt;/ul>&#xA;&#x9;&lt;/li>&#xA;&lt;/ul>&#xA;">
            <ownedFunctionalChainInvolvements xsi:type="org.polarsys.capella.core.data.fa:FunctionalChainInvolvementLink"
